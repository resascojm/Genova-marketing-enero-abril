    <div class="kpi warn"><div class="label">Bad Lead Ratio</div><div class="value" id="u-ratio">—</div><div class="sub">Por cada Good Lead, X Bad</div></div>
  </div>
</section>

<!-- ============ TRADICIONAL ============ -->
