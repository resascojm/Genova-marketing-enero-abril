<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Meta Ads Deep Dive — Guspamar</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,800;1,9..144,400&family=JetBrains+Mono:wght@400;500;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
:root{
  --ink:#0a0e27; --paper:#f5f1e8; --paper-2:#ebe5d3; --rule:#d4cdb8;
  --accent:#d62828; --accent2:#003049; --warn:#f77f00; --good:#3d8b3d;
  --muted:#5a5a5a; --meta:#1877f2;
}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--paper);color:var(--ink);line-height:1.55;font-size:15px}
.wrap{max-width:1320px;margin:0 auto;padding:48px 32px 96px}

/* HEADER */
.masthead{
  border-top:6px solid var(--ink);border-bottom:1px solid var(--ink);
  padding:24px 0 18px;margin-bottom:48px;
  display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:12px;
}
.masthead .brand{font-family:'Fraunces',serif;font-weight:800;font-size:13px;letter-spacing:.18em;text-transform:uppercase}
.masthead .date{font-family:'JetBrains Mono',monospace;font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em}

h1.hero{font-family:'Fraunces',serif;font-weight:300;font-size:clamp(48px,7vw,96px);line-height:.92;letter-spacing:-.03em;margin-bottom:24px}
h1.hero em{font-style:italic;color:var(--accent);font-weight:400}
.lede{font-family:'Fraunces',serif;font-size:22px;line-height:1.4;max-width:780px;color:var(--ink);font-weight:400;margin-bottom:8px}
.byline{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-top:32px;padding-top:16px;border-top:1px solid var(--rule)}

/* NAV */
.nav{
  position:sticky;top:0;background:var(--paper);border-top:1px solid var(--rule);border-bottom:1px solid var(--rule);
  margin:48px -32px 48px;padding:14px 32px;
  display:flex;gap:24px;overflow-x:auto;z-index:1000;
  font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.08em;text-transform:uppercase;
}
.nav a{color:var(--ink);text-decoration:none;white-space:nowrap;padding:4px 0;border-bottom:2px solid transparent;transition:.2s}
.nav a:hover{border-bottom-color:var(--accent)}

/* CHAPTER OPENERS */
.chapter-open{
  display:grid;grid-template-columns:auto 1fr;gap:32px;align-items:end;
  margin-top:96px;margin-bottom:48px;padding-bottom:24px;border-bottom:3px solid var(--ink);
}
.chapter-open .num{
  font-family:'Fraunces',serif;font-weight:200;font-size:140px;line-height:.8;color:var(--accent);
}
.chapter-open .titles h2{font-family:'Fraunces',serif;font-weight:400;font-size:64px;line-height:1;letter-spacing:-.02em}
.chapter-open .titles h2 em{font-style:italic;color:var(--accent)}
.chapter-open .titles .sub{font-family:'JetBrains Mono',monospace;font-size:11px;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-top:12px}

/* KPI BAND */
.kpis{
  display:grid;grid-template-columns:repeat(5,1fr);gap:0;
  border:1px solid var(--ink);background:var(--paper-2);margin-bottom:32px;
}
.kpi{padding:24px 20px;border-right:1px solid var(--rule);display:flex;flex-direction:column;gap:6px}
.kpi:last-child{border-right:none}
.kpi .label{font-family:'JetBrains Mono',monospace;font-size:10px;text-transform:uppercase;letter-spacing:.15em;color:var(--muted)}
.kpi .value{font-family:'Fraunces',serif;font-size:42px;font-weight:300;line-height:1;letter-spacing:-.02em}
.kpi .sub{font-size:11px;color:var(--muted);margin-top:4px}
.kpi.alert .value{color:var(--accent)}
.kpi.warn .value{color:var(--warn)}
.kpi.good .value{color:var(--good)}

/* SECTIONS */
section{margin-bottom:72px;scroll-margin-top:80px}
.section-head{margin-bottom:24px;border-bottom:1px solid var(--ink);padding-bottom:12px}
.section-num{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.15em;color:var(--accent);margin-bottom:6px;text-transform:uppercase}
.section-head h3{font-family:'Fraunces',serif;font-weight:400;font-size:32px;line-height:1.1;letter-spacing:-.01em}
.section-head h3 em{font-style:italic;color:var(--accent)}
.section-lede{font-family:'Inter',sans-serif;font-size:14px;line-height:1.5;margin-top:8px;color:#444;max-width:780px}

.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:24px;align-items:start}
.grid-2-asym{display:grid;grid-template-columns:1.4fr 1fr;gap:24px;align-items:start}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
@media(max-width:880px){
  .grid-2,.grid-2-asym,.grid-3,.kpis{grid-template-columns:1fr}
  .kpi{border-right:none;border-bottom:1px solid var(--rule)}
  .chapter-open{grid-template-columns:1fr}
  .chapter-open .num{font-size:80px}
  .chapter-open .titles h2{font-size:42px}
}

.chart-card{background:#fff;border:1px solid var(--ink);padding:20px}
.chart-title{font-family:'JetBrains Mono',monospace;font-size:10px;text-transform:uppercase;letter-spacing:.15em;color:var(--muted);margin-bottom:14px}
.chart-wrap{position:relative;height:280px}
.chart-wrap.short{height:220px}
.chart-wrap.tall{height:380px}
.map-wrap{height:480px;border:1px solid var(--ink);background:#fff}

/* TABLE */
.tbl{width:100%;border-collapse:collapse;font-size:13px}
.tbl th{font-family:'JetBrains Mono',monospace;font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);text-align:left;padding:10px 10px;border-bottom:1px solid var(--ink);font-weight:500}
.tbl td{padding:10px}
.tbl td.num{font-family:'JetBrains Mono',monospace;text-align:right}
.tbl tr{border-bottom:1px solid var(--rule)}
.tbl tr:hover{background:var(--paper-2)}

/* CELL HEATMAP */
.heat{padding:6px 10px;border-radius:2px;display:inline-block;min-width:48px;text-align:right;font-family:'JetBrains Mono',monospace}
.heat-bad{background:#f5d0d0}.heat-bad-hi{background:#e88}.heat-bad-vhi{background:#d62828;color:#fff}
.heat-good{background:#d0eed0}.heat-good-hi{background:#7cc77c;color:#fff}.heat-good-vhi{background:#3d8b3d;color:#fff}

/* TOGGLE */
.toggles{display:flex;gap:0;margin-bottom:14px;border:1px solid var(--ink);width:fit-content}
.toggle{font-family:'JetBrains Mono',monospace;font-size:11px;text-transform:uppercase;letter-spacing:.1em;padding:8px 14px;background:var(--paper);border:none;cursor:pointer;border-right:1px solid var(--rule);color:var(--ink)}
.toggle:last-child{border-right:none}
.toggle.active{background:var(--ink);color:var(--paper)}

/* FOOTER */
.foot{margin-top:64px;padding-top:24px;border-top:1px solid var(--rule);font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;text-align:center}

/* META BADGE */
.meta-tag{display:inline-block;background:var(--meta);color:#fff;padding:3px 10px;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:.1em;text-transform:uppercase;margin-bottom:12px}

/* LEAFLET TOOLTIPS */
.leaflet-tooltip-custom{background:var(--ink)!important;color:var(--paper)!important;border:none!important;font-family:'JetBrains Mono',monospace;font-size:11px;padding:6px 10px;box-shadow:none}
</style>
</head>
