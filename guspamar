    <div class="kpi alert"><div class="label">Bad Leads</div><div class="value">${fmt(t.bad)}</div><div class="sub">${t.pct_bad}% del canal</div></div>
    <div class="kpi"><div class="label">Good Leads</div><div class="value">${fmt(t.good)}</div><div class="sub">${(100-t.pct_bad).toFixed(1)}% del canal</div></div>
    <div class="kpi good"><div class="label">Ventas</div><div class="value">${t.ventas}</div><div class="sub">Conv. Good ${t.conv_good}%</div></div>
    <div class="kpi warn"><div class="label">Bad/Good ratio</div><div class="value">${(t.bad/t.good).toFixed(2)}</div><div class="sub">Bad por Good Lead</div></div>
  `;
}
renderKpis('trad-kpis', D.tradicional.totales);
renderKpis('pa-kpis', D.plan_ahorro.totales);

// === VELOCIDAD ===
function renderVelocidad(canal, prefix){
  const v = D[canal].velocidad;
  // Bar chart % Bad
  new Chart(document.getElementById(prefix+'-vel-bad'),{
    type:'bar',
    data:{labels:v.map(r=>r.vel),datasets:[{
      label:'% Bad Lead',data:v.map(r=>r.pct_bad),
      backgroundColor:v.map(r=>{
        if(r.pct_bad<40)return COLORS.good;
        if(r.pct_bad<55)return COLORS.warn;
        return COLORS.accent;
      })
    }]},
    options:{...baseOpts,plugins:{...baseOpts.plugins,legend:{display:false}},
      scales:{...baseOpts.scales,y:{...baseOpts.scales.y,ticks:{...baseOpts.scales.y.ticks,callback:v=>v+'%'}}}}
  });
  // Line/bar Conv Good
  new Chart(document.getElementById(prefix+'-vel-conv'),{
    type:'bar',
    data:{labels:v.map(r=>r.vel),datasets:[{
      label:'Conv. Good (%)',data:v.map(r=>r.conv_good),
      backgroundColor:COLORS.accent
    }]},
    options:{...baseOpts,plugins:{...baseOpts.plugins,legend:{display:false}},
      scales:{...baseOpts.scales,y:{...baseOpts.scales.y,ticks:{...baseOpts.scales.y.ticks,callback:v=>v+'%'}}}}
  });
  // Tabla
  const tbl = document.getElementById(prefix+'-vel-tbl');
  tbl.innerHTML = `<thead><tr><th>Velocidad</th><th class="num">Leads</th><th class="num">Bad</th><th class="num">Good</th><th class="num">Ventas</th><th class="num">% Bad</th><th class="num">Conv. Good</th></tr></thead><tbody>
    ${v.map(r=>{
      let badClass='heat-bad';if(r.pct_bad>50)badClass='heat-bad-hi';if(r.pct_bad>60)badClass='heat-bad-vhi';
      let goodClass='heat-good';if(r.conv_good>3)goodClass='heat-good-hi';if(r.conv_good>5)goodClass='heat-good-vhi';
      return `<tr><td><strong>${r.vel}</strong></td><td class="num">${fmt(r.leads)}</td><td class="num">${fmt(r.bad)}</td><td class="num">${fmt(r.good)}</td><td class="num">${r.ventas}</td><td class="num"><span class="heat ${badClass}">${r.pct_bad}%</span></td><td class="num"><span class="heat ${goodClass}">${r.conv_good}%</span></td></tr>`;
    }).join('')}
  </tbody>`;
}
renderVelocidad('tradicional','trad');
renderVelocidad('plan_ahorro','pa');

// === EVOLUCIÓN ===
const evolCharts = {};
function renderEvol(canal, prefix, freq){
  const evol = freq==='M' ? D[canal].evol_mensual : D[canal].evol_semanal;
  const labels = evol.map(r=>{
    if(freq==='M'){
      const m = {'2026-01':'Enero','2026-02':'Febrero','2026-03':'Marzo','2026-04':'Abril'};
      return m[r.period]||r.period;
    }
    return r.period;
  });
  
  if(evolCharts[prefix+'_vol']) evolCharts[prefix+'_vol'].destroy();
  if(evolCharts[prefix+'_eff']) evolCharts[prefix+'_eff'].destroy();
  
  evolCharts[prefix+'_vol'] = new Chart(document.getElementById(prefix+'-evol-vol'),{
    type:'bar',
    data:{labels,datasets:[
      {label:'Bad Leads',data:evol.map(r=>r.bad),backgroundColor:COLORS.accent,stack:'a'},
      {label:'Good Leads',data:evol.map(r=>r.good),backgroundColor:COLORS.accent2,stack:'a'}
    ]},
    options:{...baseOpts,scales:{x:{...baseOpts.scales.x,stacked:true},y:{...baseOpts.scales.y,stacked:true}}}
  });
  
  evolCharts[prefix+'_eff'] = new Chart(document.getElementById(prefix+'-evol-eff'),{
    type:'line',
    data:{labels,datasets:[
      {label:'% Bad Lead',data:evol.map(r=>r.pct_bad),borderColor:COLORS.accent,backgroundColor:'rgba(214,40,40,.1)',yAxisID:'y',borderWidth:2.5,tension:.3,pointRadius:4,fill:false},
      {label:'Conv. Good (%)',data:evol.map(r=>r.conv_good),borderColor:COLORS.good,backgroundColor:'rgba(61,139,61,.1)',yAxisID:'y1',borderWidth:2.5,tension:.3,pointRadius:4,fill:false}
    ]},
    options:{...baseOpts,scales:{
      x:{grid:{display:false},ticks:{font:{size:10}}},
      y:{position:'left',title:{display:true,text:'% Bad',font:{size:10}},grid:{color:'#e0d9c4'},ticks:{callback:v=>v+'%'}},
      y1:{position:'right',title:{display:true,text:'Conv. Good %',font:{size:10}},grid:{display:false},ticks:{callback:v=>v+'%'}}
    }}
  });
}
renderEvol('tradicional','trad','M');
renderEvol('plan_ahorro','pa','M');

document.querySelectorAll('[data-trad-evol]').forEach(b=>b.addEventListener('click',()=>{
  document.querySelectorAll('[data-trad-evol]').forEach(x=>x.classList.remove('active'));
  b.classList.add('active');renderEvol('tradicional','trad',b.dataset.tradEvol);
}));
document.querySelectorAll('[data-pa-evol]').forEach(b=>b.addEventListener('click',()=>{
  document.querySelectorAll('[data-pa-evol]').forEach(x=>x.classList.remove('active'));
  b.classList.add('active');renderEvol('plan_ahorro','pa',b.dataset.paEvol);
}));

// === MAPAS ===
function renderMapa(canal, divId, tblId){
  const data = D[canal].mapa;
  const map = L.map(divId,{scrollWheelZoom:false}).setView([-38,-64],6);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png',{
    attribution:'',maxZoom:18,subdomains:'abcd'
  }).addTo(map);
  
  const maxLeads = Math.max(...data.map(r=>r.leads));
  data.forEach(r=>{
    const radius = 6 + Math.sqrt(r.leads/maxLeads)*30;
    let color = COLORS.good;
    if(r.pct_bad>=40) color = COLORS.warn;
    if(r.pct_bad>=55) color = COLORS.accent;
    if(r.pct_bad>=70) color = '#7a0000';
    
    L.circleMarker([r.lat,r.lon],{
      radius,fillColor:color,color:'#fff',weight:1.5,opacity:1,fillOpacity:.7
    }).bindTooltip(
      `<strong>${r.localidad}</strong><br>${r.leads} leads · ${r.pct_bad}% bad<br>Ventas: ${r.ventas} · Conv: ${r.conv_good}%`,
      {permanent:false,direction:'top',className:'leaflet-tooltip-custom'}
    ).addTo(map);
  });
  
  // Tabla
  const tbl = document.getElementById(tblId);
  const top15 = data.slice(0,15);
  tbl.innerHTML = `<thead><tr><th>Localidad</th><th class="num">Leads</th><th class="num">% Bad</th><th class="num">Ventas</th><th class="num">Conv.</th></tr></thead><tbody>
    ${top15.map(r=>{
      let badClass='heat-bad';if(r.pct_bad>50)badClass='heat-bad-hi';if(r.pct_bad>65)badClass='heat-bad-vhi';
      let goodClass='';if(r.conv_good>0&&r.conv_good<3)goodClass='heat-good';if(r.conv_good>=3&&r.conv_good<6)goodClass='heat-good-hi';if(r.conv_good>=6)goodClass='heat-good-vhi';
      return `<tr><td>${r.localidad}</td><td class="num">${fmt(r.leads)}</td><td class="num"><span class="heat ${badClass}">${r.pct_bad}%</span></td><td class="num">${r.ventas}</td><td class="num">${r.conv_good>0?'<span class="heat '+goodClass+'">'+r.conv_good+'%</span>':r.conv_good+'%'}</td></tr>`;
    }).join('')}
  </tbody>`;
}
renderMapa('tradicional','trad-map','trad-loc-tbl');
renderMapa('plan_ahorro','pa-map','pa-loc-tbl');

// === MOTIVOS ===
// Categorías:
//   BAD_LEAD (rojo): problemas de calidad de dato — BL:* y Dato Duplicado
//   GESTION (naranja): pérdida en gestión comercial — Sin confirmación
//   CALIFICADO (azul): lead real que decidió no comprar — económico, competencia, producto, plan no interesa
//   OTRO (gris): fuera de scope, ganado, etc.
function categorizarMotivo(m){
  const s = (m||'').toLowerCase();
  if(s.startsWith('bl:') || s.includes('dato duplicado')) return 'bad';
  if(s.includes('sin confirmaci')) return 'gestion';
  if(s.includes('econ') || s.includes('mejor inversi') || s.includes('compro otra') || 
     s.includes('producto no cumple') || s.includes('pv - desisto') || s.includes('plan de ahorro') ||
     s.includes('mejor tasaci') || s.includes('compr')) return 'calificado';
  return 'otro';
}
const COLOR_CAT = {
  bad: '#d62828',
  gestion: '#f77f00',
  calificado: '#003049',
  otro: '#888'
};
const LABEL_CAT = {
  bad: 'Bad Lead (calidad de dato)',
  gestion: 'Pérdida en gestión',
  calificado: 'Decidió no comprar (calificado)',
  otro: 'Otros'
};

function renderMotivos(canal, ctxId){
  const m = D[canal].motivos;
  const cats = m.map(r=>categorizarMotivo(r.motivo));
  
  new Chart(document.getElementById(ctxId),{
    type:'bar',
    data:{labels:m.map(r=>r.motivo),datasets:[{
      label:'Cantidad',data:m.map(r=>r.count),
      backgroundColor:cats.map(c=>COLOR_CAT[c])
    }]},
    options:{...baseOpts,indexAxis:'y',plugins:{...baseOpts.plugins,legend:{display:false},
      tooltip:{...baseOpts.plugins.tooltip,callbacks:{
        label:c=>c.parsed.x+' leads ('+m[c.dataIndex].pct+'% del canal)',
        afterLabel:c=>'Categoría: '+LABEL_CAT[cats[c.dataIndex]]
      }}
    },
    scales:{x:{grid:{color:'#e0d9c4'},ticks:{font:{size:10}}},y:{grid:{display:false},ticks:{font:{size:10,family:"'JetBrains Mono', monospace"}}}}}
  });
  
  // Agregar leyenda manual debajo del canvas
  const canvas = document.getElementById(ctxId);
  const parent = canvas.closest('.chart-card');
  if(parent && !parent.querySelector('.motiv-legend')){
    const legend = document.createElement('div');
    legend.className = 'motiv-legend';
    legend.style.cssText = 'display:flex;gap:18px;flex-wrap:wrap;margin-top:14px;padding-top:14px;border-top:1px solid var(--rule);font-family:Inter;font-size:12px';
    legend.innerHTML = Object.keys(LABEL_CAT).map(k=>
      `<div style="display:flex;align-items:center;gap:6px"><span style="width:12px;height:12px;background:${COLOR_CAT[k]};display:inline-block;border-radius:2px"></span>${LABEL_CAT[k]}</div>`
    ).join('');
    parent.appendChild(legend);
  }
}
renderMotivos('tradicional','trad-motivos-ch');
renderMotivos('plan_ahorro','pa-motivos-ch');
</script>
